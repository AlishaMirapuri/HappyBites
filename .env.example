# ── App ────────────────────────────────────────────────────────────────────────
APP_NAME=HappyBites
ENVIRONMENT=development        # development | production | test
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, zero config)
DATABASE_URL=sqlite:///./happybites.db

# PostgreSQL (future upgrade — only this line changes)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/happybites

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── Reddit API ─────────────────────────────────────────────────────────────────
# Register at https://www.reddit.com/prefs/apps → "script" app type
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=HappyBites/0.1 (portfolio project)

# ── Ingestion ──────────────────────────────────────────────────────────────────
INGEST_INTERVAL_SECONDS=7200   # 2 hours
MAX_DEALS_PER_RUN=100

# ── Ranking weights (must sum to 1.0) ──────────────────────────────────────────
WEIGHT_DISCOUNT=0.40
WEIGHT_FRESHNESS=0.35
WEIGHT_QUALITY=0.25
FRESHNESS_HALFLIFE_HOURS=48.0
